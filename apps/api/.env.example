# Server
NODE_ENV=development
PORT=3001
API_PREFIX=/api/v1

# Database
DATABASE_URL=postgresql://htask:Harish%402026@localhost:5432/htask?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-me-in-production-use-strong-secret-key
JWT_REFRESH_SECRET=change-me-refresh-secret-key
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# CORS
CORS_ORIGIN=http://localhost:5173

# Storage
STORAGE_PROVIDER=local
STORAGE_LOCAL_PATH=./uploads
S3_BUCKET=htask-files
S3_REGION=us-east-1
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT=http://localhost:9000

# Email (Gmail: use App Password — https://myaccount.google.com/apppasswords)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM=your@gmail.com
APP_URL=http://localhost:5173
EMAIL_SCHEDULER_ENABLED=true

# Graylog
GRAYLOG_ENABLED=false
GRAYLOG_HOST=localhost
GRAYLOG_PORT=12201

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
